<config>
    <executableName>${app.executable}</executableName>
    <mainClass>${app.mainclass}</mainClass>
    <os>ios</os>
    <arch>thumbv7</arch>
    <target>ios</target>
    <iosInfoPList>Info.plist.xml</iosInfoPList>
    <resources>
        <resource>
            <directory>../assets</directory>
        </resource>
        <resource>
            <directory>data</directory>
        </resource>
    </resources>
    <forceLinkClasses>
        <pattern>com.apogames.aistories.**</pattern>
        <pattern>com.badlogic.gdx.scenes.scene2d.ui.*</pattern>
        <pattern>com.badlogic.gdx.graphics.g3d.particles.**</pattern>
        <pattern>com.badlogic.gdx.graphics.freetype.**</pattern>
        <pattern>javazoom.jl.decoder.**</pattern>
        <pattern>com.mpatric.mp3agic.**</pattern>
        <pattern>com.fasterxml.jackson.**</pattern>
        <pattern>com.google.gson.**</pattern>
        <pattern>okhttp3.**</pattern>
        <pattern>okio.**</pattern>
        <pattern>kotlin.**</pattern>
        <pattern>com.android.okhttp.HttpHandler</pattern>
        <pattern>com.android.okhttp.HttpsHandler</pattern>
        <pattern>com.android.org.conscrypt.**</pattern>
        <pattern>com.android.org.bouncycastle.asn1.**</pattern>
        <pattern>com.android.org.bouncycastle.crypto.**</pattern>
        <pattern>com.android.org.bouncycastle.jcajce.provider.**</pattern>
        <pattern>com.android.org.bouncycastle.jce.provider.**</pattern>
        <pattern>javax.net.ssl.**</pattern>
        <pattern>org.apache.harmony.security.provider.cert.**</pattern>
        <pattern>org.apache.harmony.security.provider.crypto.**</pattern>
    </forceLinkClasses>
</config>
